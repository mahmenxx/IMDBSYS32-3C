@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to the Login/Logout Demo</h1>
    <p class="lead">This project demonstrates ASP.NET Core Identity with Roles.</p>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="alert alert-success mt-4">
            <h4>You are logged in as <strong>@User.Identity.Name</strong></h4>
            <p>
                Your roles:
                @if (User.IsInRole("Admin"))
                {
                    <span class="badge bg-danger">Admin</span>
                }
                @if (User.IsInRole("User"))
                {
                    <span class="badge bg-primary">User</span>
                }
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info mt-4">
            <h4>You are not logged in</h4>
            <p>
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary me-2">Login</a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary">Register</a>
            </p>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <h5 class="card-title">Demo Accounts</h5>
                <table class="table table-sm">
                    <thead><tr><th>Email</th><th>Password</th><th>Role</th></tr></thead>
                    <tbody>
                        <tr><td>admin@demo.com</td><td>Admin123</td><td><span class="badge bg-danger">Admin</span></td></tr>
                        <tr><td colspan="3"><em>Register a new account to get the <span class="badge bg-primary">User</span> role</em></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
